ges/projects/65376259-76ee-4d05-bf9c-275c907f7cde/gallery/11_int_08.jpg","sort_order":11},{"id":"65376259-img-12","storage_path":"assets/images/projects/65376259-76ee-4d05-bf9c-275c907f7cde/gallery/12_int_09.jpg","sort_order":12},{"id":"65376259-img-13","storage_path":"assets/images/projects/65376259-76ee-4d05-bf9c-275c907f7cde/gallery/13_int_10.jpg","sort_order":13},{"id":"65376259-img-14","storage_path":"assets/images/projects/65376259-76ee-4d05-bf9c-275c907f7cde/gallery/14___________________________.jpg","sort_order":14}]},{"id":"dd0c1ad4-31f8-489b-98d4-8a5b23e00d8d","slug":"renovatsiya-fitness-tsentra","title":"Реновация фитнесс-центра","city":"город","year":"2022","status":"Концепция","typology":"Общественное здание","description":"Здание спортивного фитнес-центра, возведенное по проекту 2000 года, со временем утратило актуальность фасадных решений и потребовало комплексного обновления как экстерьера, так и интерьера.\n\nРазработанная концепция реновации предлагает современные лаконичные решения, призванные радикально осовременить образ объекта, сохранив при этом гармонию со сложившимся градостроительным контекстом. В качестве основного облицовочного материала выбраны крупноформатные фиброцементные панели в двух оттенках — светло- и темно-сером — с различной фактурой поверхности.\n\nДинамичная криволинейность главного фасада нарочито подчеркнута легкой ламельной оболочкой. Эта конструкция, обладая максимальной прозрачностью, с определенных ракурсов воспринимается как цельная, литая плоскость.\nВ структуру оболочки интегрирована новая входная группа, решенная в виде лаконичного портала, облицованного темно-серыми металлическими панелями. По своему цветовому решению и пропорциям портал поддерживает верхний объем здания. В рамках оформления входной группы организованы два автономных входа — в пространство фитнес-центра и в кафе, что позволяет эффективно разделить потоки посетителей.","cover_path":"assets/images/projects/dd0c1ad4-31f8-489b-98d4-8a5b23e00d8d/gallery/00_06.jpg","sort_order":12,"published":true,"project_images":[{"id":"dd0c1ad4-img-00","storage_path":"assets/images/projects/dd0c1ad4-31f8-489b-98d4-8a5b23e00d8d/gallery/00_06.jpg","sort_order":0},{"id":"dd0c1ad4-img-01","storage_path":"assets/images/projects/dd0c1ad4-31f8-489b-98d4-8a5b23e00d8d/gallery/01_07.jpg","sort_order":1},{"id":"dd0c1ad4-img-02","storage_path":"assets/images/projects/dd0c1ad4-31f8-489b-98d4-8a5b23e00d8d/gallery/02_08.jpg","sort_order":2},{"id":"dd0c1ad4-img-03","storage_path":"assets/images/projects/dd0c1ad4-31f8-489b-98d4-8a5b23e00d8d/gallery/03_09.jpg","sort_order":3},{"id":"dd0c1ad4-img-04","storage_path":"assets/images/projects/dd0c1ad4-31f8-489b-98d4-8a5b23e00d8d/gallery/04_10.jpg","sort_order":4},{"id":"dd0c1ad4-img-05","storage_path":"assets/images/projects/dd0c1ad4-31f8-489b-98d4-8a5b23e00d8d/gallery/05_11.jpg","sort_order":5},{"id":"dd0c1ad4-img-06","storage_path":"assets/images/projects/dd0c1ad4-31f8-489b-98d4-8a5b23e00d8d/gallery/06_IMG_00001.jpg","sort_order":6},{"id":"dd0c1ad4-img-07","storage_path":"assets/images/projects/dd0c1ad4-31f8-489b-98d4-8a5b23e00d8d/gallery/07______1.jpg","sort_order":7}]},{"id":"0bcaef25-f973-408e-84dd-814ecb8a6935","slug":"basseyn-maktama","title":"Бассейн Мактама","city":"город","year":"2021","status":"Концепция","typology":"Общественное здание","description":"","cover_path":"assets/images/projects/0bcaef25-f973-408e-84dd-814ecb8a6935/gallery/00_01.jpg","sort_order":13,"published":true,"project_images":[{"id":"0bcaef25-img-00","storage_path":"assets/images/projects/0bcaef25-f973-408e-84dd-814ecb8a6935/gallery/00_01.jpg","sort_order":0},{"id":"0bcaef25-img-01","storage_path":"assets/images/projects/0bcaef25-f973-408e-84dd-814ecb8a6935/gallery/01_02.jpg","sort_order":1},{"id":"0bcaef25-img-02","storage_path":"assets/images/projects/0bcaef25-f973-408e-84dd-814ecb8a6935/gallery/02_03.jpg","sort_order":2},{"id":"0bcaef25-img-03","storage_path":"assets/images/projects/0bcaef25-f973-408e-84dd-814ecb8a6935